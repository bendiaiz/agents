{
  "name": "agents",
  "version": "0.0.1",
  "description": "Fork of cloudflare/agents — a framework for building AI agents on Cloudflare Workers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "changeset": "changeset",
    "version": "tsx .github/changeset-version.ts",
    "release": "tsx .github/changeset-publish.ts"
  },
  "keywords": [
    "cloudflare",
    "agents",
    "ai",
    "durable-objects"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@cloudflare/workers-types": "^4.20240208.0",
    "@types/node": "^20.11.5",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
